  "query": "SELECT r.id, r.revision, r.effective_at, r.created_by, r.created_at, p.provider_kind AS \"provider_kind?\", p.provider_id AS \"provider_id?\", p.model AS \"model?\", p.operation AS \"operation?\", p.input_per_million::text AS \"input_per_million?\", p.output_per_million::text AS \"output_per_million?\", p.unit_price::text AS \"unit_price?\", p.currency::text AS \"currency?\" FROM pricing_revisions r LEFT JOIN prices p ON p.pricing_revision_id = r.id WHERE r.id IN (SELECT id FROM pricing_revisions WHERE ($1::int IS NULL OR revision < $1) ORDER BY revision DESC LIMIT $2) ORDER BY r.revision DESC, p.provider_kind, p.provider_id NULLS FIRST, p.model, p.operation",
