{
  "db_name": "PostgreSQL",
  "query": "SELECT rpc.provider_id AS id, rpc.kind, rpc.endpoint, rpc.cloud_region, rpc.cloud_project, rpc.deployment, rpc.api_version, rpc.auth_mode, cv.id AS \"credential_id?\", cv.version AS \"credential_version?\", cv.ciphertext AS \"ciphertext?\", cv.nonce AS \"nonce?\", cv.master_key_version AS \"master_key_version?\" FROM runtime_generation_provider_configs rpc JOIN providers p ON p.id = rpc.provider_id LEFT JOIN provider_credential_versions cv ON cv.id = rpc.active_credential_version_id AND cv.revoked_at IS NULL WHERE rpc.provider_id = $1 AND rpc.runtime_generation_id = $3 AND rpc.active_credential_version_id IS NOT DISTINCT FROM $2 AND p.active_revision_id IS NOT NULL AND p.state <> 'disabled'::provider_state AND (rpc.active_credential_version_id IS NULL OR cv.id IS NOT NULL)",
