  "query": "SELECT r.id, r.slug, rr.id AS revision_id, rr.routing_id, rr.overall_timeout_ms, rr.max_attempts FROM routes r JOIN LATERAL ( SELECT id, routing_id, overall_timeout_ms, max_attempts FROM route_revisions WHERE route_id = r.id ORDER BY revision DESC LIMIT 1 ) rr ON true ORDER BY r.slug",
