  "query": "SELECT g.id, g.sequence, encode(g.release_sha256, 'hex') AS \"sha256_hex!\", g.created_by, u.email AS created_by_email, g.created_at FROM runtime_generations g JOIN users u ON u.id = g.created_by WHERE ($1::bigint IS NULL OR g.sequence < $1) ORDER BY g.sequence DESC LIMIT $2",
