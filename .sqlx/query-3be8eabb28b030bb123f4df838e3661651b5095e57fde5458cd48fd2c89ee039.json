  "query": "SELECT oi.id, oi.issuer, oi.email_at_link, oi.last_login_at, oi.created_at, (u.password_hash IS NOT NULL OR count(*) OVER () > 1) AS \"can_unlink!\" FROM oidc_identities oi JOIN users u ON u.id = oi.user_id WHERE oi.user_id = $1 ORDER BY oi.created_at, oi.id",
