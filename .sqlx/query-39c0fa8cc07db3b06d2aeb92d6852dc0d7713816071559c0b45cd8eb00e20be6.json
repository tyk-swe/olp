  "db_name": "PostgreSQL",
  "query": "SELECT rt.id, rt.routing_id, pr.provider_id, prm.upstream_model, rt.priority, rt.weight, rt.timeout_ms FROM route_revision_targets rt JOIN provider_revision_models prm ON prm.source_provider_model_id = rt.provider_model_id JOIN provider_revisions pr ON pr.id = prm.provider_revision_id JOIN providers p ON p.id = pr.provider_id AND p.active_revision_id = pr.id WHERE rt.route_revision_id = $1 AND prm.enabled AND p.state <> 'disabled'::provider_state ORDER BY rt.position",
