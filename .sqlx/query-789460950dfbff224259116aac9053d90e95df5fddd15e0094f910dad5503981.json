  "query": "SELECT pm.id, pm.upstream_model, pm.display_name, pm.enabled, pm.discovered_at, p.id AS provider_id, p.name AS provider_name, p.kind AS provider_kind FROM provider_models pm JOIN providers p ON p.id = pm.provider_id WHERE ($1::uuid IS NULL OR pm.id > $1) AND ($2::boolean IS NULL OR pm.enabled = $2) ORDER BY pm.id LIMIT $3",
