{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:olp:policy:program:v1",
  "title": "OLP Policy Program v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "language_version", "program_id", "revision_id", "phase", "rules", "default_actions"],
  "properties": {
    "schema_version": { "const": 1 },
    "language_version": { "const": "1.0.0" },
    "program_id": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{0,62}$" },
    "revision_id": { "type": "string", "format": "uuid" },
    "phase": {
      "enum": ["credential", "admission", "request_guard", "route", "attempt_result", "reconcile"]
    },
    "rules": {
      "type": "array",
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/rule" }
    },
    "default_actions": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "#/$defs/action" }
    }
  },
  "$defs": {
    "field_path": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(?:[.][a-z][a-z0-9_]*){0,7}$",
      "maxLength": 255
    },
    "reason_code": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]{0,63}$"
    },
    "literal": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "integer", "minimum": -9223372036854775808, "maximum": 9223372036854775807 },
        { "type": "string", "maxLength": 8192 },
        { "type": "null" }
      ]
    },
    "operand": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["field"],
          "properties": { "field": { "$ref": "#/$defs/field_path" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["literal"],
          "properties": { "literal": { "$ref": "#/$defs/literal" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["decimal"],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?!-0[.]000000000$)-?(?:0|[1-9][0-9]{0,19})[.][0-9]{9}$"
            }
          }
        }
      ]
    },
    "expression": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["const"],
          "properties": { "const": { "type": "boolean" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["not"],
          "properties": { "not": { "$ref": "#/$defs/expression" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["all"],
          "properties": {
            "all": { "type": "array", "minItems": 1, "maxItems": 64, "items": { "$ref": "#/$defs/expression" } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["any"],
          "properties": {
            "any": { "type": "array", "minItems": 1, "maxItems": 64, "items": { "$ref": "#/$defs/expression" } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["compare", "left", "right"],
          "properties": {
            "compare": { "enum": ["eq", "ne", "lt", "lte", "gt", "gte"] },
            "left": { "$ref": "#/$defs/operand" },
            "right": { "$ref": "#/$defs/operand" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["present"],
          "properties": { "present": { "$ref": "#/$defs/field_path" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["in", "values"],
          "properties": {
            "in": { "$ref": "#/$defs/operand" },
            "values": { "type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true, "items": { "$ref": "#/$defs/literal" } }
          }
        }
      ]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "reason_code", "enforcement"],
      "properties": {
        "kind": {
          "enum": [
            "allow", "deny", "require_credential_class", "select_admission_policy",
            "reserve_quota", "reserve_budget", "cap_output", "add_decision_tag",
            "redact_field", "remove_field", "filter_candidate", "select_score_profile",
            "lower_attempts", "lower_concurrency", "lower_timeout", "stop", "continue",
            "mark_usage_incomplete", "commit_reservation", "release_reservation",
            "record_discrepancy", "mark_hard_control_unhealthy"
          ]
        },
        "reason_code": { "$ref": "#/$defs/reason_code" },
        "enforcement": { "enum": ["hard", "advisory"] },
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{0,62}$" },
        "integer_value": { "type": "integer", "minimum": 0, "maximum": 9223372036854775807 },
        "field_path": { "$ref": "#/$defs/field_path" },
        "candidate_ids": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "format": "uuid" }
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "when", "actions"],
      "properties": {
        "rule_id": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{0,62}$" },
        "when": { "$ref": "#/$defs/expression" },
        "actions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": { "$ref": "#/$defs/action" }
        }
      }
    }
  }
}
