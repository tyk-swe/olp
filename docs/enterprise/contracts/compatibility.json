    "phases": {
      "expand": {
        "purpose": "Add backward-readable storage without requiring it from any N-1 reader or writer.",
        "n_minus_one_required_state": "read_write",
        "application_rollback": "binary_rollback_safe"
      },
      "migrate": {
        "purpose": "Dual-write and perform bounded, restartable, observable backfill while legacy reads and writes remain authoritative.",
        "n_minus_one_required_state": "read_write",
        "application_rollback": "binary_rollback_safe"
      },
      "contract": {
        "purpose": "Remove a legacy representation only after N-1 retirement and verification that no legacy reader, writer, row, event, cursor, or idempotency replay remains.",
        "n_minus_one_required_state": "unsupported_fail_closed",
        "application_rollback": "forward_fix_or_restore"
      }
