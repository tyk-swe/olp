    "unsafe_sql_rules": [
      {
        "id": "drop-object",
        "pattern": "\\bDROP\\s+(?:(?:MATERIALIZED\\s+)?VIEW|TABLE|COLUMN|TYPE|FUNCTION|PROCEDURE|ROUTINE|(?:EVENT\\s+)?TRIGGER|INDEX|CONSTRAINT|SCHEMA|POLICY)\\b",
        "allowed_without_exception_in": [
          "contract"
        ],
        "reason": "Removing an object breaks a legacy reader or writer."
      },
      {
        "id": "immediate-constraint",
        "pattern": "\\bADD\\s+(?:CONSTRAINT\\s+[^\\s;]+\\s+)?(?:FOREIGN\\s+KEY|CHECK\\s*\\(|UNIQUE\\s*\\(|PRIMARY\\s+KEY|EXCLUDE\\b)(?!(?:(?!,\\s*ADD\\b|;).)*\\bNOT\\s+VALID\\b)",
        "allowed_without_exception_in": [],
        "reason": "An immediately enforced constraint can lock a populated table or reject an N-1 writer; expansion constraints must remain NOT VALID until separately verified."
      },
      {
        "id": "column-default",
        "pattern": "\\bADD\\s+COLUMN\\b[^;]*\\bDEFAULT\\b|\\bALTER\\s+COLUMN\\b[^;]*\\bSET\\s+DEFAULT\\b",
        "allowed_without_exception_in": [],
        "reason": "A default can rewrite older PostgreSQL tables or silently change the semantics of N-1 writes and therefore needs explicit review."
      },
      {
        "id": "drop-column-default",
        "pattern": "\\bALTER\\s+COLUMN\\b[^;]*\\bDROP\\s+DEFAULT\\b",
        "allowed_without_exception_in": [],
        "reason": "Removing a database default can turn an omitted value from an N-1 writer into NULL or an error and therefore needs mixed-version review."
      },
      {
        "id": "rename-object",
        "pattern": "\\bRENAME\\s+(?:TO|COLUMN)\\b",
        "allowed_without_exception_in": [
          "contract"
        ],
        "reason": "Renames are remove-and-add operations to an N-1 binary."
      },
      {
        "id": "set-not-null",
        "pattern": "\\bSET\\s+NOT\\s+NULL\\b|\\bADD\\s+COLUMN\\b[^;]*\\bNOT\\s+NULL\\b",
        "allowed_without_exception_in": [
          "contract"
        ],
        "reason": "A required column rejects an N-1 writer that omits it."
      },
      {
        "id": "alter-column-type",
        "pattern": "\\bALTER\\s+COLUMN\\b[^;]*\\bTYPE\\b",
        "allowed_without_exception_in": [
          "contract"
        ],
        "reason": "Type changes can narrow old reads or writes."
      },
      {
        "id": "destructive-data-change",
        "pattern": "\\b(?:DELETE\\s+FROM|TRUNCATE(?:\\s+TABLE)?)\\b",
        "allowed_without_exception_in": [
          "contract"
        ],
        "reason": "Destructive data changes require the restore decision and retired-reader proof."
      },
      {
        "id": "unbounded-sql-backfill",
        "pattern": "\\bUPDATE\\s+(?:ONLY\\s+)?(?:[A-Za-z_][A-Za-z0-9_]*\\.)?[A-Za-z_][A-Za-z0-9_]*(?:\\s+AS\\s+[A-Za-z_][A-Za-z0-9_]*)?\\s+SET\\b|\\bINSERT\\s+INTO\\b[^;]*\\bSELECT\\b",
        "allowed_without_exception_in": [],
        "reason": "Backfills must be bounded, restartable application work or carry an explicit reviewed exception."
      },
      {
        "id": "row-security-change",
        "pattern": "\\b(?:ENABLE|DISABLE|FORCE|NO\\s+FORCE)\\s+ROW\\s+LEVEL\\s+SECURITY\\b|\\b(?:CREATE|ALTER)\\s+POLICY\\b",
        "allowed_without_exception_in": [],
        "reason": "Row-level security and policy changes can silently reject or hide legacy reads and writes and require mixed-version evidence."
      },
      {
        "id": "privilege-change",
        "pattern": "\\b(?:GRANT|REVOKE)\\b",
        "allowed_without_exception_in": [],
        "reason": "Privilege changes can make an otherwise compatible N-1 workload fail during a rolling deployment."
      },
      {
        "id": "blocking-index-build",
        "pattern": "\\bCREATE\\s+(?:UNIQUE\\s+)?INDEX\\s+(?!CONCURRENTLY\\b)",
        "allowed_without_exception_in": [],
        "reason": "A blocking index build needs an explicit size and lock-budget exception."
      },
      {
        "id": "unique-index-behavior",
        "pattern": "\\bCREATE\\s+UNIQUE\\s+INDEX\\b",
        "allowed_without_exception_in": [],
        "reason": "A unique index, including a concurrent build, can reject an N-1 writer and requires mixed-version write evidence."
      },
      {
        "id": "enum-expansion",
        "pattern": "\\bALTER\\s+TYPE\\b[^;]*\\bADD\\s+VALUE\\b",
        "allowed_without_exception_in": [],
        "reason": "An N-1 closed-enum decoder may reject a value even when PostgreSQL accepts it."
      },
      {
        "id": "behavioral-database-fence",
        "pattern": "\\bCREATE\\s+(?:OR\\s+REPLACE\\s+)?(?:FUNCTION|PROCEDURE)\\b|\\bCREATE\\s+(?:OR\\s+REPLACE\\s+)?(?:(?:CONSTRAINT|EVENT)\\s+)?TRIGGER\\b|\\bCREATE\\s+RULE\\b|\\bALTER\\s+EVENT\\s+TRIGGER\\b|\\bALTER\\s+TABLE\\b[^;]*\\b(?:ENABLE|DISABLE)\\s+(?:(?:ALWAYS|REPLICA)\\s+)?TRIGGER\\b",
        "allowed_without_exception_in": [],
        "reason": "Database behavior that can reject or rewrite legacy writes must be reviewed and exercised by the mixed-version matrix."
      },
      {
        "id": "replace-view",
        "pattern": "\\bCREATE\\s+OR\\s+REPLACE\\s+VIEW\\b",
        "allowed_without_exception_in": [],
        "reason": "Replacing a view can remove columns or change row and value semantics beneath an N-1 reader without changing the view name."
      },
      {
        "id": "constraint-validation",
        "pattern": "\\bVALIDATE\\s+CONSTRAINT\\b",
        "allowed_without_exception_in": [],
        "reason": "Constraint validation requires an explicit lock and duration budget."
      }
    ]
  },
