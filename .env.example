OLP_HOST_PORT=8080
POSTGRES_PASSWORD=olp
# Keep this percent-encoded form synchronized with POSTGRES_PASSWORD.
POSTGRES_PASSWORD_URL_ENCODED=olp
OLP_DATABASE_URL=postgres://olp:${POSTGRES_PASSWORD_URL_ENCODED}@postgres:5432/olp
OLP_DATABASE_MAX_CONNECTIONS=20
OLP_HTTP_MAX_CONNECTIONS=1024
OLP_VALKEY_URL=redis://valkey:6379
OLP_PUBLIC_ORIGIN=http://localhost:${OLP_HOST_PORT}
OLP_LOCAL_LOGIN_ENABLED=true
OLP_MEDIA_SPOOL_CAPACITY_BYTES=1073741824
OLP_UID=1000
OLP_GID=1000
RUST_LOG=olp=info,tower_http=info
